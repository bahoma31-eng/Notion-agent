# Copy this file to .env for local development (never commit .env!)
# For GitHub Actions, add these as repository secrets:
# Settings → Secrets and variables → Actions → New repository secret

# GitHub Models Token (for GPT-4o via GitHub Models - free)
# Get it from: https://github.com/settings/tokens
# Or use your existing GitHub PAT with models:read permission
MODELS_TOKEN=github_pat_your_token_here

# Hugging Face API Token (free at https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Shop information in JSON format
SHOP_INFO={"shop_name": "YOUR_SHOP_NAME", "phone": "YOUR_PHONE", "location": "YOUR_LOCATION", "tagline": "YOUR_TAGLINE"}
